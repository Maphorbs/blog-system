{
  "name": "@maphorbs/blog-system",
  "version": "1.0.1",
  "description": "Universal, pluggable, database-agnostic Blog & Event CMS engine and admin dashboard for full-stack apps.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsup index.ts server.ts --format cjs,esm --dts --no-splitting --external react --external react-dom --external next --external react-hot-toast --external lucide-react --external react-quill-new --external react-quill-new/dist/quill.snow.css --external pg --external mongodb --external mysql2 --external sqlite3 --external sqlite --external firebase-admin --external uuid --external @aws-sdk/client-s3"
  },
  "keywords": [
    "nextjs",
    "react",
    "cms",
    "blog",
    "events",
    "database-agnostic",
    "postgresql",
    "supabase",
    "mongodb",
    "mysql",
    "sqlite",
    "firebase"
  ],
  "author": "Yayi Diaspora Movement",
  "license": "MIT",
  "peerDependencies": {
    "lucide-react": "^1.0.0",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-hot-toast": "^2.0.0",
    "react-quill-new": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    },
    "sqlite": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "uuid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
